{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": [
    "DATABASE_URL",
    "SESSION_SECRET",
    "NODE_ENV"
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/index.cjs"
    },
    {
      "source": "/:path*",
      "destination": "/index.cjs"
    }
  ]
}